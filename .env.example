# =========================
# YouTube Data API v3
# =========================
# https://console.cloud.google.com/ 에서 API Key 발급
YOUTUBE_API_KEY=

# =========================
# Google Gemini (요약 AI)
# =========================
# https://aistudio.google.com/app/apikey 에서 무료 키 발급 가능
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# =========================
# SMTP (이메일 알림)
# =========================
# Gmail 사용 예시:
#   1) Google 계정 보안 > 2단계 인증 활성화
#   2) 앱 비밀번호 생성 (https://myaccount.google.com/apppasswords)
#   3) 아래 SMTP_PASSWORD 에 앱 비밀번호 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=app_password_here
SMTP_FROM=your_gmail@gmail.com
NOTIFY_TO=jaykim@sooplive.com

# =========================
# Telegram Bot (모바일 푸시 알림)
# =========================
# 1) 텔레그램에서 @BotFather 검색 → /newbot 명령으로 봇 생성
#    봇 이름과 username 정한 후 토큰 발급받기
# 2) 본인이 만든 봇을 텔레그램에서 검색 → /start 한 번 누르기
# 3) 아래 TELEGRAM_BOT_TOKEN 채우고
#    python tools/find_telegram_chat_id.py 실행하면 CHAT_ID가 출력됨
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
