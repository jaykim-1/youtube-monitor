# Streamlit Community Cloud에 그대로 붙여넣으세요.
# share.streamlit.io 에서 앱 만들기 > Advanced > Secrets 에 입력

YOUTUBE_API_KEY = "여기에_유튜브_API_키"
GOOGLE_API_KEY = "여기에_제미니_API_키"
GEMINI_MODEL = "gemini-2.5-flash"

# 앱 비밀번호 (Cloud 공개 URL을 본인만 보게 막는 용도)
APP_PASSWORD = "원하는_비밀번호_8자_이상"

# 선택: 웹앱 DB 변경을 GitHub repo DB에도 커밋
# fine-grained PAT 권한: youtube-monitor repo Contents Read and write
REPO_SYNC_TOKEN = "여기에_GitHub_fine_grained_PAT"
GITHUB_REPO = "jaykim-1/youtube-monitor"
GITHUB_BRANCH = "main"
DB_REPO_PATH = "youtube_monitor.db"
